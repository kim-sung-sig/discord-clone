# Local development defaults only. Do not use these values for production.

SPRING_PROFILES_ACTIVE=postgres
POSTGRES_JDBC_URL=jdbc:postgresql://127.0.0.1:5432/discord
POSTGRES_USER=dev_user
POSTGRES_PASSWORD=dev_password
SPRING_DATA_REDIS_HOST=127.0.0.1
SPRING_DATA_REDIS_PORT=6379

# Use postgres,redis when validating Redis-backed runtime controls locally.
# Production must use production,postgres,redis with non-local secret/config values.
# SPRING_PROFILES_ACTIVE=postgres,redis

DISCORD_AUTH_ACCESS_TOKEN_SECRET=replace-with-local-32-plus-character-secret
DISCORD_GATEWAY_INTERNAL_PUBLISHER_TOKEN=replace-with-local-32-plus-character-token

NUXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080

# Reserved for T41 LiveKit production integration.
# Enable with SPRING_PROFILES_ACTIVE=postgres,redis,media-livekit for local media integration.
DISCORD_MEDIA_LIVEKIT_API_KEY=replace-when-livekit-is-enabled
DISCORD_MEDIA_LIVEKIT_API_SECRET=replace-with-32-plus-character-livekit-secret
DISCORD_MEDIA_LIVEKIT_URL=wss://livekit.example.com
