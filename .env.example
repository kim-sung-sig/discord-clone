# Local development defaults only. Do not use these values for production.

SPRING_PROFILES_ACTIVE=postgres,redis,kafka
POSTGRES_JDBC_URL=jdbc:postgresql://127.0.0.1:15432/discord
POSTGRES_USER=dev_user
POSTGRES_PASSWORD=dev_password
SPRING_FLYWAY_LOCATIONS=classpath:db/migration
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_DATA_REDIS_HOST=127.0.0.1
SPRING_DATA_REDIS_PORT=16379
SPRING_DATA_REDIS_PASSWORD=dev_password
SPRING_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:29092
DISCORD_KAFKA_ENABLED=true
DISCORD_KAFKA_TOPIC_PREFIX=discord
DISCORD_KAFKA_GATEWAY_DLQ_RETENTION_HOURS=168
DISCORD_KAFKA_GATEWAY_DLQ_ALERT_THRESHOLD=1
DISCORD_GATEWAY_SESSION_REGISTRY_KEY=gateway:sessions
DISCORD_GATEWAY_SESSION_TTL_SECONDS=86400
DISCORD_GATEWAY_REDIS_STREAM_CONSUMER_GROUP=discord-gateway
DISCORD_GATEWAY_REDIS_STREAM_MAX_LENGTH=10000
DISCORD_GATEWAY_REDIS_DLQ_STREAM=gateway:dead-letter
DISCORD_GATEWAY_REDIS_DLQ_ALERT_THRESHOLD=1

# Local Docker Desktop resource names:
# - postgres-source: 127.0.0.1:15432 -> 5432
# - ms-redis: 127.0.0.1:16379 -> 6379
# - ms-kafka: 127.0.0.1:29092 -> 29092
# Production must use production,postgres,redis,kafka with non-local secret/config values.

DISCORD_AUTH_ACCESS_TOKEN_SECRET=replace-with-local-32-plus-character-secret
DISCORD_GATEWAY_INTERNAL_PUBLISHER_TOKEN=replace-with-local-32-plus-character-token

NUXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
# Set a Postgres URL to persist normalized CSP telemetry in the central database.
# Local docker postgresSource default:
NUXT_CSP_TELEMETRY_POSTGRES_URL=postgres://dev_user:dev_password@127.0.0.1:15432/discord
# Optional T99 telemetry retention controls.
NUXT_CSP_TELEMETRY_RETENTION_MAX_ENTRIES=1000
NUXT_CSP_TELEMETRY_RETENTION_MAX_AGE_DAYS=
# Optional T102 Redis-backed CSP report limiter controls.
# Local default uses ms-redis instead of per-process in-memory limiting.
NUXT_CSP_REPORT_RATE_LIMIT_REDIS_URL=redis://:dev_password@127.0.0.1:16379
NUXT_CSP_REPORT_RATE_LIMIT_MAX_REPORTS=60
NUXT_CSP_REPORT_RATE_LIMIT_WINDOW_MS=60000
# Optional T104 trusted proxy controls for CSP report rate-limit subjects.
# Leave empty to ignore spoofable forwarded headers and use the direct peer address.
NUXT_CSP_RATE_LIMIT_TRUSTED_PROXY_CIDRS=
# Optional T100 CSP dashboard alert thresholds.
NUXT_CSP_ALERT_TOTAL_THRESHOLD=
NUXT_CSP_ALERT_DIRECTIVE_THRESHOLD=
# Optional T105 dashboard RBAC controls.
# Prefer backend verification, then local JWT verification.
# NUXT_SECURITY_DASHBOARD_TOKEN is a bootstrap secret for issuing short-lived operator tokens.
NUXT_SECURITY_DASHBOARD_AUTH_CHECK_URL=
NUXT_SECURITY_DASHBOARD_JWT_SECRET=
NUXT_SECURITY_DASHBOARD_ADMIN_USER_IDS=
NUXT_SECURITY_DASHBOARD_ADMIN_ROLES=
NUXT_SECURITY_DASHBOARD_ADMIN_SCOPES=
NUXT_SECURITY_DASHBOARD_TOKEN=replace-with-local-dashboard-bootstrap-token
NUXT_SECURITY_DASHBOARD_OPERATOR_TOKEN_POSTGRES_URL=
NUXT_SECURITY_DASHBOARD_REQUIRE_GUARD=false

# Reserved for T41 LiveKit production integration.
# Enable with SPRING_PROFILES_ACTIVE=postgres,redis,media-livekit for local media integration.
DISCORD_MEDIA_LIVEKIT_API_KEY=replace-when-livekit-is-enabled
DISCORD_MEDIA_LIVEKIT_API_SECRET=replace-with-32-plus-character-livekit-secret
DISCORD_MEDIA_LIVEKIT_URL=wss://livekit.example.com

# Optional real LiveKit media smoke. Disabled by default.
LIVEKIT_MEDIA_SMOKE=0
REAL_BACKEND_BASE_URL=http://127.0.0.1:8080
LIVEKIT_URL=ws://127.0.0.1:7880
