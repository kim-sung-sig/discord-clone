{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Discord Clone",
  "version": "0.1.0",
  "identifier": "com.discordclone.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -w apps/web",
    "beforeBuildCommand": "npm run build -w apps/web",
    "devUrl": "http://127.0.0.1:3000",
    "frontendDist": "../../web/.output/public"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Discord Clone",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
